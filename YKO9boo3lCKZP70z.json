    {
      "parameters": {
        "jsCode": "const tasks = $input.all().map(item => item.json);\n\n// 1. Gruppierung nach Personen (User)\nconst groupedByUser = tasks.reduce((groups, task) => {\n  // E-Mail-Bereinigung (z.B. bei Paul)\n  const user = task.User.replace(/@neuro-pulse\\.de/g, \"\");\n  if (!groups[user]) groups[user] = [];\n  groups[user].push(task);\n  return groups;\n}, {});\n\n// 2. Zusammenbau der Nachricht\nlet urgentCount = tasks.filter(t => \n  (t.Priority?.toLowerCase().includes(\"hoch\") || t.Priority?.toLowerCase().includes(\"kritisch\"))\n).length;\n\nlet message = `⚠️ *ÜBERFÄLLIGE AUFGABEN*\\n`;\nmessage += `Status: ${tasks.length} offen | 🚨 ${urgentCount} Dringend\\n`;\nmessage += `––––––––––––––––––––––––––\\n\\n`;\n\n// Sortierung der User alphabetisch für bessere Struktur\nconst sortedUsers = Object.keys(groupedByUser).sort();\n\nfor (const user of sortedUsers) {\n  message += `👤 *${user}*\\n`;\n\n  // Innerhalb der Person nach Datum sortieren\n  groupedByUser[user].sort((a, b) => new Date(a.Date) - new Date(b.Date));\n\n  for (const task of groupedByUser[user]) {\n    const dateFormatted = task.Date.split('-').reverse().join('.');\n    const priority = task.Priority ? task.Priority.toLowerCase() : \"\";\n    const taskText = task.task.toLowerCase();\n    \n    // Icon-Logik: Kreuze für Überfälliges\n    let icon = \"❌\"; \n    let label = \"\";\n\n    // Zusatz-Label bei hoher Priorität oder kritischen Themen\n    if (priority.includes(\"hoch\") || priority.includes(\"kritisch\")) {\n      label = \"*[DRINGEND]* \";\n    } \n\n    // Zeile: Icon + Datum + Task + Prio (falls vorhanden)\n    message += `${icon} \\`${dateFormatted}\\`: ${label}${task.task}`;\n    if (task.Priority && !label.includes(\"DRINGEND\")) {\n      message += ` (_${task.Priority}_)`;\n    }\n    message += `\\n`;\n  }\n  message += `\\n`; // Abstand zwischen den Personen\n}\n\nmessage += `––––––––––––––––––––––––––\\n`;\nmessage += `_Bitte priorisiert abarbeiten, um den Workflow bei Neuro•Pulse nicht zu gefährden._`;\n\nreturn [{\n  json: {\n    telegram_text: message,\n    parse_mode: \"Markdown\"\n  }\n}];"
      },
