    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst completedTasks = items.map(item => {\n  return {\n    name: item.json.name,\n    // Sicherstellen, dass der User-Text existiert, sonst \"Unbekannt\"\n    user: item.json.column_values && item.json.column_values[1] ? item.json.column_values[1].text : \"Team\"\n  };\n});\n\n// Gruppierung nach User\nconst grouped = completedTasks.reduce((groups, task) => {\n  const user = task.user;\n  if (!groups[user]) groups[user] = [];\n  groups[user].push(task.name);\n  return groups;\n}, {});\n\nlet message = \"✅ *Neuro•Pulse – Erfolgreich erledigt*\\n\";\nmessage += \"––––––––––––––––––––––––––\\n\\n\";\n\nfor (const user in grouped) {\n  // E-Mail-Bereinigung (z.B. für Paul)\n  const displayName = user.replace(/@neuro-pulse\\.de/g, \"\");\n  \n  message += `👤 *${displayName}*\\n`;\n  \n  for (const taskName of grouped[user]) {\n    // Icons basierend auf Task-Inhalt (optionales Extra)\n    let icon = \"✔️\";\n\n    message += `${icon} \\`${taskName}\\` \\n`;\n  }\n  message += \"\\n\";\n}\n\nmessage += \"––––––––––––––––––––––––––\\n\";\nmessage += \"💪 *Gute Arbeit, Team!*\";\n\nreturn [{\n  json: {\n    telegram_text: message,\n    parse_mode: \"Markdown\"\n  }\n}];"
      },
